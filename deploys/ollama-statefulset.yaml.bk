apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: ollama
  namespace: ollama
  labels:
    app: ollama
spec:
  serviceName: "ollama"
  replicas: 3
  selector:
    matchLabels:
      app: ollama
  template:
    metadata:
      labels:
        app: ollama
    spec:
      containers:
      - name: ollama
        image: iad.ocir.io/idi1o0a010nx/ai/ollama:latest
        ports:
        - containerPort: 11434
        volumeMounts:
        - name: ollama-storage
          mountPath: /root/.ollama
        command: ["/bin/sh", "-c"]
        args:
          - |
            echo "Starting Ollama server..."
            ollama serve &
            echo "Waiting for server to be ready..."
            sleep 10
            echo "Pulling models..."
            ollama pull gemma3:1b
            ollama pull llama3.2:3b
            ollama pull gpt-oss:20b
            echo "All models are ready. Keeping Ollama running..."
            tail -f /dev/null
  volumeClaimTemplates:
  - metadata:
      name: ollama-storage
    spec:
      accessModes: ["ReadWriteOnce"]
      storageClassName: sc-ollama
      resources:
        requests:
          storage: 200Gi

